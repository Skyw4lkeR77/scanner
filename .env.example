# ─────────────────────────────────────────────────────────
# OWASP TOP 10 ONLINE SCANNER — Environment Configuration
# Enhanced Version with Xray Integration & Asia/Jakarta Timezone
# ─────────────────────────────────────────────────────────

# Application Mode: development / production
APP_ENV=development

# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change-me-in-production-use-random-64-chars

# Server bind
APP_HOST=0.0.0.0
APP_PORT=8000

# Timezone (default: Asia/Jakarta - WIB UTC+7)
TIMEZONE=Asia/Jakarta

# Database URL (SQLite or PostgreSQL)
# SQLite: sqlite:///./scanner.db
# PostgreSQL: postgresql://user:password@localhost:5432/scanner_db
DATABASE_URL=sqlite:///./scanner.db

# Redis URL for job queue
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════
# SCANNER TOOLS CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ─── Nuclei Configuration ─────────────────────────────────
NUCLEI_BIN=/usr/local/bin/nuclei
# Nuclei templates directory
NUCLEI_TEMPLATES=~/nuclei-templates
# Nuclei rate limit (requests per second)
NUCLEI_RATE_LIMIT=50
# Nuclei concurrency
NUCLEI_CONCURRENCY=25

# ─── Katana Configuration ─────────────────────────────────
KATANA_BIN=/usr/local/bin/katana

# ─── Xray (Chaitin) Configuration ─────────────────────────
# Xray binary path (download from: https://docs.xray.cool/)
XRAY_BIN=/usr/local/bin/xray
# Xray plugins to enable (comma-separated)
# Community Edition: xss,sqldet,cmd-injection,dirscan,path-traversal,xxe,upload,brute-force,jsonp,ssrf,baseline,redirect,crlf-injection
# Advanced Edition (if licensed): add struts,thinkphp,shiro,fastjson
XRAY_PLUGINS=xss,sqldet,cmd-injection,dirscan,path-traversal,xxe,upload,brute-force,jsonp,ssrf,baseline,redirect,crlf-injection

# ═══════════════════════════════════════════════════════════
# SCAN SETTINGS
# ═══════════════════════════════════════════════════════════

# Scan limits
MAX_CONCURRENT_SCANS_PER_USER=5
MAX_CONCURRENT_SCANS_GLOBAL=20

# Rate limiting for scan submissions (per minute)
RATE_LIMIT_SCAN=5

# Session expiry (hours)
SESSION_EXPIRY_HOURS=8

# Scan output directory
SCAN_OUTPUT_DIR=/tmp/scanner-outputs

# Log directory
LOG_DIR=./logs

# Raw output retention (days)
RAW_OUTPUT_RETENTION_DAYS=90

# ═══════════════════════════════════════════════════════════
# COMPREHENSIVE SCAN TIMEOUTS (seconds)
# ═══════════════════════════════════════════════════════════

# Maximum scan duration for comprehensive mode
COMPREHENSIVE_SCAN_TIMEOUT=7200
# Maximum Xray scan duration
XRAY_SCAN_TIMEOUT=3600
# Maximum Katana crawl duration
KATANA_SCAN_TIMEOUT=1800

# ═══════════════════════════════════════════════════════════
# SECURITY & DEPLOYMENT
# ═══════════════════════════════════════════════════════════

# Allowed hosts (comma-separated, for CORS in production)
ALLOWED_HOSTS=scanner.example.com

# ═══════════════════════════════════════════════════════════
# INSTALLATION INSTRUCTIONS
# ═══════════════════════════════════════════════════════════

# 1. Nuclei Installation:
#    go install -v github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
#    nuclei -update-templates

# 2. Katana Installation:
#    go install github.com/projectdiscovery/katana/cmd/katana@latest

# 3. Xray Installation:
#    Download from: https://github.com/chaitin/xray/releases
#    Extract and place binary in /usr/local/bin/xray or configure XRAY_BIN path
#    ./xray version

# ═══════════════════════════════════════════════════════════
# SCAN MODES EXPLANATION
# ═══════════════════════════════════════════════════════════

# FAST Mode (~5-15 min):
#   - Basic Nuclei scan only
#   - Higher rate limit for quick results
#   - Good for: Initial reconnaissance, frequent scans

# DEEP Mode (~30-60 min):
#   - Katana crawling to discover endpoints
#   - Nuclei scan on discovered endpoints
#   - Xray scan (if available)
#   - Good for: Thorough assessment of single applications

# COMPREHENSIVE Mode (~1-2 hours):
#   - Extended timeout for thorough crawling
#   - All tools enabled with maximum coverage
#   - Slower rate limit for better accuracy
#   - Good for: Production release verification, security audits
